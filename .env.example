# ─── Configuração do app ──────────────────────────────────────────────────
# Atualmente todas as variáveis abaixo são placeholders — a app roda 100%
# com mocks. Quando trocar pelo backend real, popule e renomeie pra .env.

# URL base da API REST (ainda não consumida)
VITE_API_BASE_URL=http://localhost:3001

# Endpoint do WebSocket pra leituras RFID ao vivo (planejado pra v1.0)
VITE_WS_URL=ws://localhost:3001/ws

# Chave pública opcional para Sentry/observabilidade
# VITE_SENTRY_DSN=

# Build / ambiente
# VITE_APP_ENV=development
